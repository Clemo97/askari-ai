	<string>Saves incident photos and videos to your device library.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>Accesses your photo library to attach existing media to incident reports.</string>
	<key>UIBackgroundModes</key>
	<array>
		<string>location</string>
		<string>processing</string>
	</array>
	<key>UILaunchScreen</key>
	<dict>
		<key>UIColorName</key>
		<string></string>
	</dict>
